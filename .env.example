# FareRadar 环境变量（§4.4 密钥矩阵）；复制为 .env 并填值，.env 不入 git。
# psycopg 连接串（本地/Railway 公网串）
DATABASE_URL=
# 飞书自定义机器人 webhook（批处理侧推送用）
FEISHU_WEBHOOK_URL=
# 飞书自建应用（API 侧回复指令用），仅 Railway/本地 API 需要
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# 事件订阅校验 token
FEISHU_VERIFICATION_TOKEN=
# SerpAPI 兜底 + 冷启动，仅批处理侧需要
SERPAPI_KEY=
# 时区
TZ=Asia/Singapore
# =1 时把阈值临时抬到 P95，用于 UAT-02（按需）
TEST_FORCE_BREACH=
